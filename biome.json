{
  "$schema": "https://biomejs.dev/schemas/1.8.3/schema.json",
  "organizeImports": {
    "enabled": true
  },
  "linter": {
    "rules": {
      "recommended": true,
      "correctness": {
        "noUnusedVariables": "error",
        "noUnusedPrivateClassMembers": "error",
        "noUnusedLabels": "error",
        "noEmptyPattern": "error",
        "noUnreachable": "error",
        "noUnnecessaryContinue": "error",
        "noUnnecessaryBreak": "error"
      },
      "suspicious": {
        "noExplicitAny": "error",
        "noEmptyBlockStatements": "error",
        "noDebugger": "error",
        "noConsole": "warn",
        "noPrototypeBuiltins": "error",
        "noSparseArray": "error",
        "noUnsafeNegation": "error",
        "noUnsafeOptionalChaining": "error",
        "noUnusedLabels": "error",
        "noVar": "error",
        "useNamespaceKeyword": "error"
      },
      "style": {
        "useConst": "error",
        "useTemplate": "error",
        "noNonNullAssertion": "error",
        "noParameterAssign": "error",
        "noDangle": "error"
      },
      "complexity": {
        "noNestedTernary": "error",
        "noForEach": "error"
      },
      "a11y": {
        "useAltText": "error",
        "useAriaPropsForRole": "error",
        "useButtonType": "error",
        "useSemanticElements": "error"
      }
    }
  },
  "formatter": {
    "indentStyle": "space",
    "indentWidth": 2,
    "lineEnding": "lf",
    "lineWidth": 100,
    "files": {
      "include": ["**/*.{ts,tsx,js,jsx,json,css,md}"],
      "exclude": ["**/node_modules/**", "**/.next/**", "**/dist/**"]
    }
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "double",
      "trailingCommas": "es5",
      "semicolons": "always",
      "arrowParentheses": "always"
    }
  },
  "typescript": {
    "formatter": {
      "quoteStyle": "double",
      "trailingCommas": "es5",
      "semicolons": "always",
      "arrowParentheses": "always"
    }
  },
  "files": {
    "include": ["src/**/*.{ts,tsx}", "*.{ts,tsx,json}"],
    "exclude": ["**/node_modules/**", "**/.next/**", "**/dist/**"]
  }
}
